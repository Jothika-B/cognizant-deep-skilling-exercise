import { Component } from '@angular/core';
import { bootstrapApplication } from '@angular/platform-browser';
import { provideRouter, RouterOutlet, RouterLink, RouterLinkActive, Routes } from '@angular/router';
import { FormsModule } from '@angular/forms';


 1. HOME COMPONENT (Demonstrating Data Binding)

@Component({
  selector: 'app-home',
  standalone: true,
  imports: [FormsModule],
  template: `
    <h2>Home Component</h2>
    <hr>

    <h3>1. Interpolation</h3>
    <p>Welcome back, <strong>{{ username }}</strong>!</p>

    <h3>2. Property Binding</h3>
    <img [src]="imageUrl" alt="Angular Logo" width="50"><br><br>
    <button [disabled]="isDisabled">Disabled Button</button>

    <h3>3. Event Binding</h3>
    <button (click)="toggleButton()">Toggle the button above</button>

    <h3>4. Two-Way Data Binding</h3>
    <input type="text" [(ngModel)]="feedback" placeholder="Type something...">
    <p>Live Preview: <em>{{ feedback }}</em></p>
  `
})
export class HomeComponent {
  username = 'Alex';
  isDisabled = true;
  imageUrl = 'https://angular.dev/assets/images/logos/angular/angular.svg';
  feedback = 'Initial feedback';

  toggleButton() {
    this.isDisabled = !this.isDisabled;
  }
}

